{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gate B Corpus Item",
  "type": "object",
  "required": ["item_id", "domain_id", "source_id", "source_url", "snapshot_version", "publication_date", "retrieval_date", "author_cluster_id", "license_name", "license_uri", "license_verified_at", "language", "original_language", "raw_sha256", "normalized_sha256", "token_count", "provenance_status"],
  "properties": {
    "item_id": {"type": "string", "pattern": "^GB-[A-Z0-9-]+$"},
    "domain_id": {"enum": ["D1_PMC_OA", "D2_STACKEXCHANGE", "D3_GLOBAL_VOICES"]},
    "source_id": {"type": "string"},
    "source_url": {"type": "string", "format": "uri"},
    "snapshot_version": {"type": "string"},
    "publication_date": {"type": "string", "format": "date", "maximum": "2021-12-31"},
    "retrieval_date": {"type": "string", "format": "date"},
    "author_cluster_id": {"type": "string"},
    "source_family_id": {"type": "string"},
    "license_name": {"type": "string"},
    "license_uri": {"type": "string", "format": "uri"},
    "license_verified_at": {"type": "string", "format": "date-time"},
    "attribution": {"type": "string"},
    "language": {"const": "en"},
    "original_language": {"const": "en"},
    "raw_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "normalized_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "token_count": {"type": "integer", "minimum": 50},
    "year_stratum": {"type": "string"},
    "length_stratum": {"type": "string"},
    "sensitive_content": {"type": "boolean"},
    "generated_or_translated_disclosure": {"type": "boolean"},
    "provenance_status": {"const": "verified"},
    "exclusion_reason": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
